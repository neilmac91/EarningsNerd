# EarningsNerd backend — example environment file.
# Copy to `.env` and fill in real values:  cp .env.example .env
# Only SECRET_KEY and OPENAI_API_KEY are strictly required for a useful local run.
# Everything else has a sane default (see app/config.py) or enables an optional feature.

# ── Core (required) ─────────────────────────────────────────────────────────
# JWT signing key. REQUIRED — the app refuses to start without it, and rejects this placeholder
# and any value under 32 chars. Generate a strong one and paste it here:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# AI summarization via an OpenAI-compatible endpoint. Default: DeepSeek V4 (platform.deepseek.com).
# For Google AI Studio instead: OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# and AI_DEFAULT_MODEL=gemini-3.1-pro-preview (max_tokens is auto-capped at Gemini's 8192).
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
AI_DEFAULT_MODEL=deepseek-v4-pro

# ── Database & cache ────────────────────────────────────────────────────────
# Defaults to a local SQLite file if unset; use Postgres for anything real.
DATABASE_URL=postgresql://user:password@localhost:5432/earningsnerd
REDIS_URL=redis://localhost:6379
# Set true to skip Redis entirely (production runs L1 in-memory cache only).
SKIP_REDIS_INIT=false

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# ── Auth & security ─────────────────────────────────────────────────────────
# Social sign-in (optional). The id_token from each provider is cryptographically
# verified server-side; leave blank to disable that provider's button/endpoint.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://api.earningsnerd.io/api/auth/google/callback
APPLE_CLIENT_ID=          # Apple Services ID, e.g. io.earningsnerd.web (Apple Sign In)
# APPLE_REDIRECT_URI=https://api.earningsnerd.io/api/auth/apple/callback
# Screen new/reset passwords against the HaveIBeenPwned breach corpus (k-anonymity,
# fail-open). Default true; set false to disable the outbound check.
PWNED_PASSWORD_CHECK_ENABLED=true
# Bot defense (NOT yet wired — see tasks/security_privacy_runbook.md). Add a Cloudflare
# Turnstile secret here when ready to enable signup/login CAPTCHA.
# TURNSTILE_SECRET_KEY=

# ── Payments (Stripe) — needed for Pro subscriptions ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_YEARLY_ID=

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=EarningsNerd <onboarding@resend.dev>
RESEND_WEBHOOK_SECRET=

# ── Analytics & error tracking (optional) ───────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=

# ── External market-data APIs (optional enrichment) ─────────────────────────
FINNHUB_API_KEY=
FMP_API_KEY=

# ── SEC EDGAR ───────────────────────────────────────────────────────────────
# SEC requires a descriptive User-Agent with contact info.
SEC_USER_AGENT=EarningsNerd/1.0 (contact@earningsnerd.io)
