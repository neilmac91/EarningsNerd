# EarningsNerd frontend — example environment file.
# Copy to `.env.local` and adjust:  cp .env.local.example .env.local
# Defaults work for local dev against a backend on http://localhost:8000.

# Base URL of the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Analytics (optional). Leave blank to disable PostHog locally.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error tracking (optional). Client + server DSN for Sentry.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Feature flags (default off unless set to "true").
NEXT_PUBLIC_ENABLE_FINANCIAL_CHARTS=false
NEXT_PUBLIC_ENABLE_SECTION_TABS=false
NEXT_PUBLIC_ENABLE_QUALITY_BADGE=false
NEXT_PUBLIC_ENABLE_RECOMMENDED_FILING=false
# Sign in with Apple button (backend Apple exchange + Apple Developer setup must be live first).
NEXT_PUBLIC_ENABLE_APPLE_SIGNIN=false
# Multi-filing Compare feature (nav entry, watchlist CTA, /compare routes). Off until the
# un-summarized-filing flow is reworked; when off the routes 404 so direct URLs are hidden too.
NEXT_PUBLIC_ENABLE_COMPARE=false

# Cloudflare Turnstile (bot defense) site key. When set, the Turnstile widget renders on the
# login/register/contact/waitlist forms. The backend must also have TURNSTILE_SECRET_KEY set —
# until BOTH are configured, the widget renders nothing and verification is a no-op.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Gate summary generation behind auth (false = guests can generate).
NEXT_PUBLIC_REQUIRE_AUTH_FOR_SUMMARY=false

# Filing id used by the homepage "example summary" link (optional).
NEXT_PUBLIC_EXAMPLE_FILING_ID=

# Waitlist/pre-launch gating (server-side). true = waitlist mode on.
WAITLIST_MODE=false
