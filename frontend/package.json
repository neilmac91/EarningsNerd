{
  "name": "earningsnerd-frontend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "lhci": "lhci autorun",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "clean": "rimraf .next",
    "clean:all": "rimraf .next node_modules/.cache",
    "dev:clean": "npm run clean && npm run dev",
    "deploy": "npx vercel --prod",
    "brand:assets": "node scripts/generate-brand-assets.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.63.0",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.5.2",
    "axios": "^1.18.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "lodash": "^4.18.1",
    "next": "16.2.10",
    "postcss": "^8.5.15",
    "posthog-js": "^1.396.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "@lhci/cli": {
      "tmp": "0.2.7",
      "uuid": "14.0.1",
      "js-yaml": "5.1.0",
      "inquirer": "14.0.2"
    },
    "jsdom": {
      "undici": "^7.28.0"
    }
  }
}
