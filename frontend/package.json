{
  "name": "earningsnerd-frontend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "lhci": "lhci autorun",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "clean": "rimraf .next",
    "clean:all": "rimraf .next node_modules/.cache",
    "dev:clean": "npm run clean && npm run dev",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.59.0",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.5.0",
    "axios": "^1.18.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "lodash": "^4.18.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "postcss": "^8.5.15",
    "posthog-js": "^1.392.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vercel": "^54.14.5",
    "vitest": "^4.1.9"
  }
}
